# Overlay for second camera slave (flash with SDKCONFIG_DEFAULTS including this file).
# Slave 1 (default): node 1 @ 192.168.1.20
# Slave 2:          node 2 @ 192.168.1.21
# PC receiver stays 192.168.1.10 — both slaves uplink to the same tcp_receiver.py.

CONFIG_RPI_NODE_ID=2
CONFIG_RPI_ETH_STATIC_IP="192.168.1.21"
CONFIG_RPI_ETH_STATIC_GW="192.168.1.10"
CONFIG_RPI_ETH_STATIC_NETMASK="255.255.255.0"
